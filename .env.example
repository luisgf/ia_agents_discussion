GITHUB_TOKEN=ghp_your_token_here
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Only models available on GitHub Models are supported.
# OpenAI: openai/gpt-4.1, openai/gpt-4o, openai/gpt-4o-mini, openai/o1, ...
# Meta:   meta/llama-3.3-70b-instruct, ...
# Others: mistral-ai/mistral-large-2411, microsoft/phi-4, cohere/command-r-plus, ...
# NOTE: Anthropic and Google models are NOT available through GitHub Models.
DIAGNOSTIC_MODEL=openai/gpt-4.1
SKEPTIC_MODEL=openai/gpt-4o
MODERATOR_MODEL=openai/gpt-4o-mini

# ── Thinking / reasoning level (per agent) ─────────────────────────────
# none | low | medium | high. Only sent to reasoning models
# (o1/o3/o4 families, gpt-5, and all Claude models); silently ignored
# for the rest (e.g. gpt-4o) — the UI warns when this happens.
DIAGNOSTIC_REASONING_EFFORT=none
SKEPTIC_REASONING_EFFORT=none
MODERATOR_REASONING_EFFORT=none

MAX_ROUNDS=4
CONFIDENCE_THRESHOLD=0.8

# ── Prompt templates ────────────────────────────────────────────────────
# Default template (default | performance | errors | data | security)
# and language (es | en). Admins can add/override templates by
# placing <name>.<lang>.yaml in PROMPTS_DIR.
PROMPT_TEMPLATE=default
PROMPT_LANGUAGE=en
# PROMPTS_DIR=/home/youruser/.local/share/agents-discussion/prompts

# ── Tool configuration ──────────────────────────────────────────────────
TOOLS_ENABLED=true
# Limit per agent and round (1-50)
MAX_TOOL_CALLS_PER_AGENT=8
# Comma-separated list to limit the exposed tools (empty = all):
# ENABLED_TOOLS=run_ssh_command,http_get,query_prometheus

# ── Human approval of tools (web runs only) ─────────────────────────────
# Sensitive tools require operator approval in the UI before they
# run. Every call is recorded in DATA_DIR/audit.jsonl.
TOOL_APPROVAL_REQUIRED=true
APPROVAL_REQUIRED_TOOLS=run_ssh_command,run_local_command,run_kubectl,run_db_explain
APPROVAL_TIMEOUT_SECONDS=300
COMMENT_TIMEOUT_SECONDS=600

# ── Observability endpoints for tools (optional) ────────────────────────
# PROMETHEUS_URL=http://prometheus:9090
# LOKI_URL=http://loki:3100
# ELASTICSEARCH_URL=http://elasticsearch:9200
# DATABASE_URL=postgres://user:pass@host:5432/db

# ── Web server ─────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ── SSH defaults ────────────────────────────────────────────────────────
SSH_DEFAULT_USER=admin
SSH_KEY_PATH=/home/youruser/.ssh/id_rsa
SSH_CONNECT_TIMEOUT=15

# ── SSL / Corporate proxy ───────────────────────────────────────────────
REQUESTS_CA_BUNDLE=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem

# ── GitHub Copilot provider (optional) ─────────────────────────────────
# Long-lived OAuth token (ghu_...) that does NOT expire.
# To obtain it, run once:
#   agents-discuss-copilot-auth
# The script performs the OAuth device flow, stores the token in
# ~/.config/agents-discussion/copilot_token and verifies it.
# Session tokens (~25 min lifetime) are renewed automatically.
#
# Alternative: copy the token here directly after authentication.
COPILOT_TOKEN=ghu_xxxxxxxxxxxxxxxxxxxx

# To use Copilot models, prefix the name with "copilot/":
#   DIAGNOSTIC_MODEL=copilot/gpt-4o
#   SKEPTIC_MODEL=copilot/claude-3.5-sonnet
#   MODERATOR_MODEL=copilot/gemini-2.0-flash-001
#
# Models available via Copilot (no prefix in the value after the slash):
#   gpt-4o, gpt-4o-mini, o1, o3-mini
#   claude-3.5-sonnet   ← Copilot exclusive (not available on GitHub Models)
#   gemini-2.0-flash-001 ← Copilot exclusive (not available on GitHub Models)

# ── Token cost estimation ─────────────────────────────────────────────────
# Optional JSON file with per-model prices (USD/1M tokens).
# Format: { "<model>": { "input": <price>, "output": <price> } }
# Example: { "gpt-4o": { "input": 2.50, "output": 10.00 } }
# If not set, the built-in price table is used (pricing.py).
# MODEL_PRICES_FILE=/path/to/model_prices.json
